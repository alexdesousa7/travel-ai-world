# App Config
PROJECT_NAME="Travel AI World"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# Security
# REQUIRED — generate with: py -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=""
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="60"

# Google OAuth 2.0 (REQUIRED)
# Get yours at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# NVIDIA AI Chat (REQUIRED for /chat endpoint)
# Get yours at: https://build.nvidia.com/
NVIDIA_API_KEY=""

# Frontend URL (for CORS — set to your deployed frontend in production)
FRONTEND_URL="http://localhost:3000"

# Database Selection (postgresql, mysql, sqlite)
DB_ENGINE="postgresql"

# Postgres/MySQL Config
# NOTE: Use "db_postgres" when running inside Docker Compose,
#       Use "127.0.0.1" when running locally without Docker.
DB_SERVER="127.0.0.1"
DB_USER="postgres"
DB_PASSWORD=""
DB_NAME="postgres"
DB_PORT="5432"

# SQLite Config (alternative — set DB_ENGINE="sqlite" to use)
SQLITE_FILE="sqlite.db"

